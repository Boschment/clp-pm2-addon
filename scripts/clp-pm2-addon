#!/bin/bash
# Wrap entire script so bash parses the whole file before executing — prevents
# corruption when we overwrite /usr/local/bin/clp-pm2-addon (i.e. ourselves).
{
set -e

# CloudPanel PM2 Addon
# Adds a "PM2" tab to Node.js sites in CloudPanel for managing the PM2
# ecosystem config and process lifecycle (start/stop/restart, live status).
# Auto-installs PM2 (in the site user's nvm) when a Node.js site is created.

ADDON_DIR="/opt/clp-pm2-addon"
DATA_DIR="$ADDON_DIR/data"
CLP_APP="/home/clp/htdocs/app/files"
CLP_TEMPLATES="$CLP_APP/templates/Frontend/Site"
CLP_CONTROLLERS="$CLP_APP/src/Controller/Frontend"
CLP_CSS="$CLP_APP/public/assets/css/frontend"
CLP_ROUTES="$CLP_APP/config/routes.yaml"
TAB_TEMPLATE="$CLP_TEMPLATES/Partial/tab-container.html.twig"
SUDOERS_FILE="/etc/sudoers.d/clp-pm2-addon"
APT_HOOK="/etc/apt/apt.conf.d/99-clp-pm2-addon"
SYSTEMD_DIR="/etc/systemd/system"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
log_ok()   { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_err()  { echo -e "${RED}[ERROR]${NC} $1"; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        log_err "This script must be run as root."
        exit 1
    fi
}

is_patched() {
    grep -q "clp_site_pm2" "$CLP_ROUTES" 2>/dev/null && \
    grep -q "clp_site_pm2" "$TAB_TEMPLATE" 2>/dev/null
}

patch_tab_container() {
    if grep -q "clp_site_pm2" "$TAB_TEMPLATE" 2>/dev/null; then
        log_ok "PM2 tab already present"
        return 0
    fi

    # Insert a Twig-conditional <li> before the closing </ul>.
    # Conditional checks several plausible site-type attribute names so the
    # patch works across CloudPanel versions; if none match it simply hides.
    python3 - "$TAB_TEMPLATE" << 'PYEOF'
import sys, re
path = sys.argv[1]
with open(path) as f: src = f.read()
snippet = """    {% set _clpPm2Type = '' %}
    {% if site.type is defined %}{% set _clpPm2Type = site.type %}{% endif %}
    {% if _clpPm2Type == '' and site.siteType is defined %}{% set _clpPm2Type = site.siteType %}{% endif %}
    {% if _clpPm2Type == '' and site.application is defined %}{% set _clpPm2Type = site.application %}{% endif %}
    {% if _clpPm2Type|lower in ['nodejs','node','node.js','nodejssite'] %}
    <li {% if active == 'pm2' %}class="active"{% endif %}>
      <a href="{{ path('clp_site_pm2', {'domainName': site.domainName}) }}">{% trans %}PM2{% endtrans %}</a>
    </li>
    {% endif %}
"""
new = re.sub(r'(\s*</ul>)', '\n' + snippet + r'\1', src, count=1)
with open(path, 'w') as f: f.write(new)
PYEOF

    if grep -q "clp_site_pm2" "$TAB_TEMPLATE"; then
        log_ok "PM2 tab patched into tab-container.html.twig"
    else
        log_err "Failed to patch tab-container.html.twig"
        return 1
    fi
}

patch_routes() {
    if grep -q "clp_site_pm2:" "$CLP_ROUTES" 2>/dev/null; then
        log_ok "Routes already present"
        return 0
    fi

    cat >> "$CLP_ROUTES" << 'ROUTES'

# CloudPanel PM2 Addon
clp_site_pm2:
  path: /site/{domainName}/pm2
  controller: App\Controller\Frontend\Pm2Controller::index

clp_site_pm2_save_config:
  path: /site/{domainName}/pm2/save-config
  controller: App\Controller\Frontend\Pm2Controller::saveConfig
  methods: POST

clp_site_pm2_start:
  path: /site/{domainName}/pm2/start
  controller: App\Controller\Frontend\Pm2Controller::start
  methods: POST

clp_site_pm2_stop:
  path: /site/{domainName}/pm2/stop
  controller: App\Controller\Frontend\Pm2Controller::stop
  methods: POST

clp_site_pm2_restart:
  path: /site/{domainName}/pm2/restart
  controller: App\Controller\Frontend\Pm2Controller::restart
  methods: POST

clp_site_pm2_status:
  path: /site/{domainName}/pm2/status
  controller: App\Controller\Frontend\Pm2Controller::status

clp_site_pm2_save_user:
  path: /site/{domainName}/pm2/save-user
  controller: App\Controller\Frontend\Pm2Controller::saveUser
  methods: POST
ROUTES

    grep -q "clp_site_pm2:" "$CLP_ROUTES" && log_ok "Routes appended" || { log_err "Failed to patch routes.yaml"; return 1; }
}

copy_files() {
    cp "$ADDON_DIR/src/Controller/Frontend/Pm2Controller.php" "$CLP_CONTROLLERS/Pm2Controller.php"
    cp "$ADDON_DIR/templates/Frontend/Site/pm2.html.twig" "$CLP_TEMPLATES/pm2.html.twig"
    cp "$ADDON_DIR/public/assets/css/frontend/pm2.css" "$CLP_CSS/pm2.css"
    chown clp:clp "$CLP_CONTROLLERS/Pm2Controller.php" "$CLP_TEMPLATES/pm2.html.twig" "$CLP_CSS/pm2.css"
    chmod 770 "$CLP_CONTROLLERS/Pm2Controller.php" "$CLP_TEMPLATES/pm2.html.twig" "$CLP_CSS/pm2.css"
    log_ok "Addon files copied"
}

ensure_data_dir() {
    mkdir -p "$DATA_DIR"
    chown clp:clp "$DATA_DIR"
    chmod 750 "$DATA_DIR"
    log_ok "Data dir ready at $DATA_DIR"
}

install_helpers() {
    # Use install(1) (atomic temp+rename) so the running script's fd stays
    # valid when we overwrite ourselves.
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-pm2-addon"       /usr/local/bin/clp-pm2-addon
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-pm2-helper"      /usr/local/bin/clp-pm2-helper
    install -m 755 -o root -g root "$ADDON_DIR/scripts/clp-pm2-autoinstall" /usr/local/bin/clp-pm2-autoinstall
    log_ok "Helper scripts installed"
}

install_sudoers() {
    cat > "$SUDOERS_FILE" << 'SUDO'
# CloudPanel PM2 Addon
clp ALL=(root) NOPASSWD: /usr/local/bin/clp-pm2-helper
SUDO
    chmod 440 "$SUDOERS_FILE"
    if ! visudo -c -f "$SUDOERS_FILE" >/dev/null 2>&1; then
        rm -f "$SUDOERS_FILE"
        log_warn "sudoers snippet failed validation and was removed"
    else
        log_ok "sudoers snippet installed"
    fi
}

install_systemd_units() {
    cp "$ADDON_DIR/systemd/clp-pm2-autoinstall.path"    "$SYSTEMD_DIR/clp-pm2-autoinstall.path"
    cp "$ADDON_DIR/systemd/clp-pm2-autoinstall.service" "$SYSTEMD_DIR/clp-pm2-autoinstall.service"
    systemctl daemon-reload
    systemctl enable --now clp-pm2-autoinstall.path >/dev/null 2>&1 || true
    log_ok "systemd path watcher installed and enabled"

    # Run once to handle pre-existing node sites.
    /usr/local/bin/clp-pm2-autoinstall || true
}

ensure_dependencies() {
    if ! command -v python3 >/dev/null 2>&1; then
        apt-get install -y python3 >/dev/null 2>&1 || log_warn "could not auto-install python3"
    fi
}

clear_cache() {
    su -s /bin/bash -c "cd $CLP_APP && php bin/console cache:clear --env=prod 2>&1" clp >/dev/null
    log_ok "Symfony cache cleared"
}

install_apt_hook() {
    cat > "$APT_HOOK" << 'HOOK'
DPkg::Post-Invoke { "if [ -x /usr/local/bin/clp-pm2-addon ]; then /usr/local/bin/clp-pm2-addon repair --quiet 2>/dev/null || true; fi"; };
HOOK
    log_ok "APT hook installed at $APT_HOOK"
}

cmd_install() {
    check_root
    echo "Installing CloudPanel PM2 Addon..."
    [ -d "$ADDON_DIR" ] || { log_err "Addon source not found at $ADDON_DIR"; exit 1; }
    [ -d "$CLP_APP" ]  || { log_err "CloudPanel not found at $CLP_APP"; exit 1; }

    ensure_dependencies
    ensure_data_dir
    install_helpers
    copy_files
    patch_tab_container
    patch_routes
    install_sudoers
    install_systemd_units
    install_apt_hook
    clear_cache

    echo ""
    log_ok "Installation complete!"
    echo "  Open CloudPanel and navigate to a Node.js site — you should see a PM2 tab."
}

cmd_repair() {
    local quiet=false
    [ "$1" = "--quiet" ] && quiet=true

    if is_patched && \
       [ -f "$CLP_CONTROLLERS/Pm2Controller.php" ] && \
       [ -f "$CLP_TEMPLATES/pm2.html.twig" ] && \
       [ -f "$CLP_CSS/pm2.css" ]; then
        $quiet || log_ok "All patches intact, nothing to repair."
        return 0
    fi

    $quiet || echo "Repairing CloudPanel PM2 Addon..."
    [ -d "$ADDON_DIR" ] || { $quiet || log_err "Addon source missing"; return 1; }

    copy_files
    patch_tab_container
    patch_routes
    clear_cache

    $quiet || log_ok "Repair complete!"
}

cmd_check() {
    echo "Checking CloudPanel PM2 Addon status..."
    local all_ok=true
    [ -f "$CLP_CONTROLLERS/Pm2Controller.php" ] && log_ok "Pm2Controller.php present" || { log_err "Pm2Controller.php MISSING"; all_ok=false; }
    [ -f "$CLP_TEMPLATES/pm2.html.twig" ]      && log_ok "pm2.html.twig present"      || { log_err "pm2.html.twig MISSING"; all_ok=false; }
    [ -f "$CLP_CSS/pm2.css" ]                  && log_ok "pm2.css present"            || { log_err "pm2.css MISSING"; all_ok=false; }
    grep -q "clp_site_pm2" "$CLP_ROUTES" 2>/dev/null && log_ok "Routes configured"   || { log_err "Routes MISSING"; all_ok=false; }
    grep -q "clp_site_pm2" "$TAB_TEMPLATE" 2>/dev/null && log_ok "PM2 tab present"   || { log_err "PM2 tab MISSING"; all_ok=false; }
    [ -f "$APT_HOOK" ]                         && log_ok "APT hook installed"        || log_warn "APT hook not installed"
    [ -f "$SYSTEMD_DIR/clp-pm2-autoinstall.path" ] && log_ok "systemd path unit installed" || log_warn "systemd path unit missing"
    systemctl is-active clp-pm2-autoinstall.path >/dev/null 2>&1 && log_ok "Path watcher active" || log_warn "Path watcher inactive"
    [ -d "$DATA_DIR" ]                         && log_ok "Data directory present"    || { log_err "Data directory MISSING"; all_ok=false; }
    echo ""
    $all_ok && log_ok "Everything looks good!" || log_err "Issues detected. Run 'clp-pm2-addon repair'."
}

cmd_uninstall() {
    check_root
    echo "Uninstalling CloudPanel PM2 Addon..."
    rm -f "$CLP_CONTROLLERS/Pm2Controller.php" "$CLP_TEMPLATES/pm2.html.twig" "$CLP_CSS/pm2.css"

    sed -i '/# CloudPanel PM2 Addon/,/^$/d' "$CLP_ROUTES" 2>/dev/null || true
    # Remove our injected tab block (between marker comments would be cleaner;
    # match by content here).
    python3 - "$TAB_TEMPLATE" << 'PYEOF' 2>/dev/null || true
import sys, re
p = sys.argv[1]
src = open(p).read()
src = re.sub(r"\n\s*\{% set _clpPm2Type.*?\{% endif %\}\n", "\n", src, flags=re.S)
open(p, 'w').write(src)
PYEOF

    systemctl disable --now clp-pm2-autoinstall.path 2>/dev/null || true
    rm -f "$SYSTEMD_DIR/clp-pm2-autoinstall.path" "$SYSTEMD_DIR/clp-pm2-autoinstall.service"
    systemctl daemon-reload

    rm -f "$APT_HOOK" "$SUDOERS_FILE"
    rm -f /usr/local/bin/clp-pm2-helper /usr/local/bin/clp-pm2-autoinstall

    clear_cache

    log_ok "Addon removed."
    log_warn "Stored ecosystem configs in $DATA_DIR were NOT removed."
    log_warn "Already-installed PM2 instances in site users were NOT removed."
    log_warn "To purge: rm -rf $ADDON_DIR /usr/local/bin/clp-pm2-addon $DATA_DIR"
}

case "${1:-}" in
    install)   cmd_install ;;
    repair)    cmd_repair "${2:-}" ;;
    check)     cmd_check ;;
    uninstall) cmd_uninstall ;;
    *)
        echo "CloudPanel PM2 Addon"
        echo "Usage: clp-pm2-addon {install|repair|check|uninstall}"
        ;;
esac
exit $?
}
